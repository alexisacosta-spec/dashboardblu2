# ─────────────────────────────────────────────
# CONFIGURACIÓN DEL PORTAL GERENCIAL DINERS
# ─────────────────────────────────────────────

# Puerto del servidor (no cambiar si no es necesario)
PORT=3000

# Clave secreta para sesiones (no compartir)
JWT_SECRET=diners_blu_portal_secret_2026_CentroHub

# ─── CONFIGURACIÓN DE EMAIL ───
# centrohub.co usa Google Workspace → SMTP de Gmail
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USER=alexis.acosta@centrohub.co
# ⚠️  ACCIÓN REQUERIDA: reemplaza el valor de abajo con tu Contraseña de Aplicación
# Pasos para obtenerla (2 minutos):
#   1. Ve a https://myaccount.google.com/security
#   2. Asegúrate de tener la Verificación en 2 pasos activada
#   3. Busca "Contraseñas de aplicaciones" (o ve a https://myaccount.google.com/apppasswords)
#   4. Selecciona app: Correo  |  dispositivo: Mac
#   5. Copia los 16 caracteres que genera y pégalos aquí (sin espacios)
MAIL_PASS=L3opold0.2025
MAIL_FROM=Portal Canales <alexis.acosta@centrohub.co>

# ─── MODO DESARROLLO ───
# true  → el OTP aparece en la consola (sin enviar email, útil para pruebas)
# false → envía el OTP por correo real (requiere MAIL_PASS configurado)
DEV_MODE=false
